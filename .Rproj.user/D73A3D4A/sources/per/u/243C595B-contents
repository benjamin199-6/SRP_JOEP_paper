  filter(Round != 1 & !is.na(Clicks_Round1)) %>%
  group_by(Round, Feedback, Interaction) %>%
  summarise(
    Mean_Change = mean(Change_from_R1, na.rm = TRUE),
    SE_Change   = sd(Change_from_R1, na.rm = TRUE) / sqrt(n()),
    N           = n(),
    .groups = "drop"
  )

