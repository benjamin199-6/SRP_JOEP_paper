# --- Step 1: Compute absolute change from Round 1 for each participant ---
df_changes <- filtered_df %>%
  arrange(Subject, Round) %>%
  group_by(Subject) %>%
  mutate(
    # Safely get baseline (Round 1) clicks, fallback = first available round
    Clicks_Round1 = Clicks[Round == 1][1],
    Clicks_Round1 = if_else(is.na(Clicks_Round1),
                            first(Clicks, order_by = Round),
                            Clicks_Round1),
    Change_from_R1 = if_else(Round == 1, 0, Clicks - Clicks_Round1)
  ) %>%
  ungroup() %>%
  mutate(
    Interaction = interaction(Condition_Uncertainty, Condition_SRP, sep = "_")
  )

