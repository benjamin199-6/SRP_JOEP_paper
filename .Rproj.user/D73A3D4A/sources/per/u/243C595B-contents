library(dplyr)
library(mediation)

# ----------------------------------------
# 1. Prepare data
# ----------------------------------------
df_amb <- filtered_df %>%
  filter(Condition_Uncertainty == "Ambiguity") %>%
  mutate(
    exp_bombs = (0 * Belief_0 + 1 * Belief_1 + 2 * Belief_2) / 100,
    p_low_bombs = (Belief_0 + Belief_1) / 100
  ) %>%
  filter(!is.na(Condition_SRP), !is.na(exp_bombs), !is.na(Clicks)) %>%
  droplevels() %>%
  mutate(Condition_SRP = factor(Condition_SRP, levels = c("Low", "High")))

# ----------------------------------------
# 2. Simple models
# ----------------------------------------

# (a) Belief model: SRP → Beliefs
belief_model <- lm(exp_bombs ~ Condition_SRP, data = df_amb)
summary(belief_model)
# Expect negative coefficient on SRPLow → High SRP expect fewer bombs

# (b) Reduced form: SRP → Clicks
clicks_model <- lm(Clicks ~ Condition_SRP, data = df_amb)
summary(clicks_model)
# Expect negative coefficient on SRPLow → High SRP take more risk (more clicks)

# (c) Full model: SRP + Beliefs → Clicks
clicks_model_med <- lm(Clicks ~ Condition_SRP + exp_bombs, data = df_amb)
summary(clicks_model_med)
# Expect exp_bombs negative; SRP coefficient drops when beliefs included

# ----------------------------------------
# 3. Mediation analysis
# ----------------------------------------
set.seed(1234)
med_results <- mediate(
  model.m = belief_model,
  model.y = clicks_model_med,
  treat = "Condition_SRP",
  mediator = "exp_bombs",
  treat.value = "High",
  control.value = "Low",
  robustSE = TRUE,
  sims = 2000
)
summary(med_results)

# ----------------------------------------
# 4. Optional robustness with alternative mediator
# ----------------------------------------
set.seed(1234)
