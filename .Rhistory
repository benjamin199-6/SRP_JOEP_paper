Delta_Clicks ~ Condition_SRP + Clicks,
data = worse_df
)
se_safer <- sqrt(diag(vcovHC(model_safer, type = "HC1")))
se_worse <- sqrt(diag(vcovHC(model_worse, type = "HC1")))
stargazer(
model_safer,
model_worse,
