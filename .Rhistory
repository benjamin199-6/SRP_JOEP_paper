# Prepare feedback variable (1 = bomb, 0 = no bomb)
df_reg <- filtered_df %>%
arrange(Subject, Round) %>%
group_by(Subject) %>%
mutate(
Feedback_prev = lag(Feedback),
Feedback_prev_bin = if_else(Feedback_prev == "Feedback_bomb", 1, 0),
Delta_Clicks = Clicks - lag(Clicks)  # or use your Percent_Change_Clicks
) %>%
ungroup() %>%
filter(!is.na(Delta_Clicks)) %>%
mutate(
Ambiguity = if_else(Condition_Uncertainty == "Ambiguity", 1, 0),
High_SRP  = if_else(Condition_SRP == "High", 1, 0)
)
# Regression with interaction terms
model_feedback <- feols(
Delta_Clicks ~ Feedback_prev_bin * Ambiguity * High_SRP,
cluster = ~Subject,   # cluster SEs at participant level
data = df_reg
)
summary(model_feedback)
