ols_all_1 <- lm(model_1, data = analysis_data)
ols_all_2 <- lm(model_2, data = analysis_data)
se_ols_all_1 <- sqrt(diag(vcovHC(ols_all_1, type = "HC1")))
se_ols_all_2 <- sqrt(diag(vcovHC(ols_all_2, type = "HC1")))
