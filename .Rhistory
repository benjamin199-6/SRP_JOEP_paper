pois_all_1$fit,
pois_all_2$fit,
ols_all_1,
ols_all_2,
type = "text",   # change to "latex" for paper
title = "Pooled Regression Results (All Rounds)",
dep.var.labels = "Clicks",
column.labels = c(
"Poisson: Main",
"Poisson: Interaction",
"OLS: Main",
"OLS: Interaction"
),
# ---- IMPORTANT PART ----
coef = list(
pois_all_1$mfxest[,1],
pois_all_2$mfxest[,1],
coef(ols_all_1),
coef(ols_all_2)
),
se = list(
pois_all_1$mfxest[,2],
pois_all_2$mfxest[,2],
se_ols_all_1,
se_ols_all_2
),
digits = 3,
align = TRUE,
no.space = TRUE
)
